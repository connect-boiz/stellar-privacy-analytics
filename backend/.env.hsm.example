# HSM Configuration
HSM_ENDPOINT=https://your-hsm-provider.com:8443
HSM_API_KEY=your-api-key
HSM_API_SECRET=your-api-secret
HSM_CLIENT_ID=stellar-backend

# Mutual TLS Configuration (Optional)
HSM_CLIENT_CERT_PATH=/path/to/client.crt
HSM_CLIENT_KEY_PATH=/path/to/client.key
HSM_CA_CERT_PATH=/path/to/ca.crt

# Key Management
HSM_KEY_ROTATION_DAYS=90
HSM_CONNECTION_TIMEOUT=10000
HSM_REQUEST_TIMEOUT=30000

# Audit Configuration
AUDIT_LOG_PATH=./logs/audit.log
AUDIT_SIGNATURE_KEY=your-signature-key-for-integrity
AUDIT_RETENTION_DAYS=90

# Kill Switch Configuration
KILL_SWITCH_AUTO_RECOVERY=false
KILL_SWITCH_RECOVERY_DELAY_MINUTES=30
KILL_SWITCH_MAX_FAILED_AUTH=10
KILL_SWITCH_MAX_SUSPICIOUS_REQUESTS=5
KILL_SWITCH_MAX_KEY_ANOMALIES=3
KILL_SWITCH_MAX_SYSTEM_ERRORS=15
KILL_SWITCH_METRICS_WINDOW=5

# Cache Configuration
DATA_KEY_CACHE_SIZE=1000
DATA_KEY_CACHE_TTL=3600

# Security Settings
MASTER_KEY_MAX_USAGE=1000000
MASTER_KEY_GRACE_PERIOD_DAYS=7
